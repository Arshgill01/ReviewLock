{
  "name": "reviewlock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "vite build --mode server",
    "build": "vite build",
    "dev": "devvit playtest",
    "type-check": "tsc --build",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "test": "vitest run --config vitest.config.ts",
    "prettier": "prettier --write .",
    "deploy": "npm run type-check && npm run lint && npm run test && devvit upload",
    "launch": "npm run deploy && devvit publish"
  },
  "dependencies": {
    "@devvit/web": "0.12.24",
    "devvit": "0.12.24",
    "hono": "^4.10.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
